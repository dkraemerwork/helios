{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": ".",
    "noEmit": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "sourceMap": false,
    "removeComments": false,
    "paths": {
      "@zenystx/helios-core/*": ["../../dist/src/*"],
      "@zenystx/helios-blitz/*": ["./src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules", "test"]
}
