{
  "name": "@helios/blitz",
  "version": "1.0.0",
  "description": "Helios Blitz — NATS-backed stream & batch processing engine",
  "private": false,
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    },
    "./*": {
      "import": "./dist/src/*.js",
      "types": "./dist/src/*.d.ts"
    }
  },
  "files": [
    "dist/src",
    "README.md"
  ],
  "scripts": {
    "build": "bun run tsc --project tsconfig.build.json",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "bun run tsc --noEmit",
    "prepublish": "bun run build"
  },
  "keywords": [
    "helios",
    "blitz",
    "nats",
    "stream",
    "batch",
    "processing",
    "distributed",
    "typescript",
    "bun"
  ],
  "author": "Helios Contributors",
  "license": "Apache-2.0",
  "dependencies": {
    "@helios/core": "file:../..",
    "@nats-io/jetstream": "^3.3.1",
    "@nats-io/kv": "^3.3.1",
    "@nats-io/transport-node": "^3.3.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.3.3",
    "nats-server": "*",
    "typescript": "beta"
  }
}
