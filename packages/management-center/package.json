{
  "name": "@zenystx/helios-management-center",
  "version": "1.0.0",
  "description": "Helios Management Center — real-time cluster monitoring, metrics visualization, alerting, and administration",
  "type": "module",
  "private": false,
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    },
    "./*": {
      "import": "./dist/src/*.js",
      "types": "./dist/src/*.d.ts"
    }
  },
  "files": [
    "dist/src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@zenystx/helios-core": "^1.0.0",
    "@libsql/client": "^0.14.0",
    "@nestjs/common": "^11.1.14",
    "@nestjs/core": "^11.1.14",
    "@nestjs/platform-fastify": "^11.1.14",
    "@nestjs/websockets": "^11.1.14",
    "@nestjs/platform-ws": "^11.1.14",
    "@nestjs/event-emitter": "^3.0.0",
    "@nestjs/schedule": "^5.0.0",
    "@nestjs/serve-static": "^5.0.0",
    "@fastify/static": "^8.1.0",
    "argon2": "^0.41.1",
    "nodemailer": "^6.10.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "uuid": "^11.1.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.14",
    "@types/bun": "latest",
    "@types/node": "^25.3.3",
    "@types/nodemailer": "^6.4.17",
    "@types/uuid": "^10.0.0",
    "typescript": "beta"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0"
  },
  "scripts": {
    "build": "bun run tsc --project tsconfig.build.json",
    "start": "bun run src/main.ts",
    "start:dev": "bun --watch run src/main.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "bun run tsc --noEmit",
    "prepack": "bun run build",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "helios",
    "management-center",
    "monitoring",
    "dashboard",
    "metrics",
    "alerting",
    "turso",
    "nestjs",
    "typescript",
    "bun"
  ],
  "author": "Helios Contributors",
  "license": "Apache-2.0"
}
