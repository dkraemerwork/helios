{
  "name": "@zenystx/helios-nestjs",
  "version": "1.0.0",
  "description": "Helios NestJS integration — @Module, @Injectable, cache, transactions, DI",
  "private": false,
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    },
    "./cache": {
      "import": "./dist/src/cache.js",
      "types": "./dist/src/cache.d.ts"
    },
    "./transaction": {
      "import": "./dist/src/transaction.js",
      "types": "./dist/src/transaction.d.ts"
    },
    "./health": {
      "import": "./dist/src/health.js",
      "types": "./dist/src/health.d.ts"
    },
    "./events": {
      "import": "./dist/src/events.js",
      "types": "./dist/src/events.d.ts"
    },
    "./decorators": {
      "import": "./dist/src/decorators.js",
      "types": "./dist/src/decorators.d.ts"
    },
    "./autoconfiguration": {
      "import": "./dist/src/autoconfiguration.js",
      "types": "./dist/src/autoconfiguration.d.ts"
    },
    "./context": {
      "import": "./dist/src/context.js",
      "types": "./dist/src/context.d.ts"
    },
    "./*": {
      "import": "./dist/src/*.js",
      "types": "./dist/src/*.d.ts"
    }
  },
  "files": [
    "dist/src",
    "README.md"
  ],
  "scripts": {
    "build": "bun run build:core && bun run tsc --project tsconfig.build.json",
    "build:core": "bun run --cwd ../.. build",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "bun run tsc --noEmit",
    "prepublish": "bun run build",
    "prepack": "bun run build"
  },
  "keywords": [
    "hazelcast",
    "helios",
    "nestjs",
    "distributed",
    "in-memory",
    "cache",
    "transaction",
    "typescript",
    "bun"
  ],
  "author": "Helios Contributors",
  "license": "Apache-2.0",
  "dependencies": {
    "@zenystx/helios-core": "file:../..",
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/common": "^11.1.14",
    "@nestjs/core": "^11.1.14",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/terminus": "^11.1.1",
    "cache-manager": "^7.2.8",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.14",
    "@types/bun": "latest",
    "@types/node": "^25.3.3",
    "typescript": "beta"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0"
  }
}
