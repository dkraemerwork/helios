{
  "compilerOptions": {
    "target": "ES2025",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2025"],

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noUncheckedSideEffectImports": true,

    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    "paths": {
      "@helios/core": ["../../src/index.ts"],
      "@helios/core/*": ["../../src/core/*", "../../src/*"],
      "@helios/nestjs": ["../../packages/nestjs/src/index.ts"],
      "@helios/nestjs/*": ["../../packages/nestjs/src/*"],
      "@helios/mongodb": ["../../packages/mongodb/src/index.ts"],
      "@helios/s3": ["../../packages/s3/src/index.ts"],
      "@helios/turso": ["../../packages/turso/src/index.ts"],
      "@helios/*": ["../../src/*"]
    },

    "types": ["bun"]
  },
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules"]
}
