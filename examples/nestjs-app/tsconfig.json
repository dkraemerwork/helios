{
  "compilerOptions": {
    "target": "ES2025",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2025"],

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noUncheckedSideEffectImports": true,

    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    "paths": {
      "@zenystx/helios-core": ["../../src/index.ts"],
      "@zenystx/helios-core/*": ["../../src/core/*", "../../src/*"],
      "@zenystx/helios-nestjs": ["../../packages/nestjs/src/index.ts"],
      "@zenystx/helios-nestjs/*": ["../../packages/nestjs/src/*"],
      "@zenystx/helios-blitz": ["../../packages/blitz/src/index.ts"],
      "@zenystx/helios-blitz/*": ["../../packages/blitz/src/*"],
      "@zenystx/helios-blitz/nestjs": ["../../packages/blitz/src/nestjs/index.ts"],
      "@zenystx/helios-mongodb": ["../../packages/mongodb/src/index.ts"],
      "@zenystx/helios-s3": ["../../packages/s3/src/index.ts"],
      "@zenystx/helios-turso": ["../../packages/turso/src/index.ts"],
      "@zenystx/helios-dynamodb": ["../../packages/dynamodb/src/index.ts"],
      "@zenystx/helios-management-center": ["../../packages/management-center/src/index.ts"]
    },

    "types": ["bun"]
  },
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules"]
}
