# Scylla Cloud / Alternator DynamoDB-compatible endpoint
# Alternator uses HTTPS on port 8043 for Scylla Cloud
DYNAMODB_ENDPOINTS=https://node-0.aws-eu-central-1.<cluster-id>.clusters.scylla.cloud:8043,https://node-1.aws-eu-central-1.<cluster-id>.clusters.scylla.cloud:8043,https://node-2.aws-eu-central-1.<cluster-id>.clusters.scylla.cloud:8043
DYNAMODB_REGION=eu-central-1
DYNAMODB_ACCESS_KEY_ID=your-access-key
DYNAMODB_SECRET_ACCESS_KEY=your-secret-key

# MongoDB (optional)
MONGO_URI=mongodb://localhost:27017
MONGO_DB=helios-example

# S3 (optional)
S3_BUCKET=helios-example
S3_ENDPOINT=http://localhost:9000
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# Turso (optional)
TURSO_URL=file:./data/sessions.db
TURSO_AUTH_TOKEN=
