{
  "name": "@zenystx/helios-nestjs-example",
  "version": "1.0.0",
  "description": "NestJS example demonstrating near-cache, predicates, MapStore persistence (MongoDB, S3, Turso), and Blitz stream processing (Binance WebSocket) using @zenystx/helios-nestjs",
  "private": true,
  "scripts": {
    "start": "bun run src/main.ts",
    "stream": "bun run src/client-market-streamer.ts",
    "stress": "bun run src/stress/stress-test.ts",
    "mc": "MC_SERVER_PORT=9090 MC_CLUSTERS='[{\"id\":\"stress\",\"displayName\":\"Stress Cluster\",\"memberAddresses\":[\"127.0.0.1:18081\"],\"restPort\":18081,\"autoDiscover\":true}]' bun run ../../packages/management-center/src/main.ts",
    "typecheck": "bun run tsc --noEmit"
  },
  "dependencies": {
    "@zenystx/helios-blitz": "file:../../packages/blitz",
    "@zenystx/helios-core": "link:../..",
    "@zenystx/helios-dynamodb": "file:../../packages/dynamodb",
    "@zenystx/helios-management-center": "file:../../packages/management-center",
    "@zenystx/helios-mongodb": "file:../../packages/mongodb",
    "@zenystx/helios-nestjs": "file:../../packages/nestjs",
    "@zenystx/helios-s3": "file:../../packages/s3",
    "@zenystx/helios-turso": "file:../../packages/turso",
    "reflect-metadata": "^0.2.2",
    "@nestjs/common": "^11.1.14",
    "@nestjs/core": "^11.1.14",
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/terminus": "^11.1.1",
    "cache-manager": "^7.2.8",
    "rxjs": "^7.8.2",
    "mongodb": "^6.12.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@libsql/client": "^0.14.0",
    "@aws-sdk/client-dynamodb": "^3.918.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "beta"
  }
}
