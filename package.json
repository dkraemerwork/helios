{
  "name": "@zenystx/helios-core",
  "version": "1.0.0",
  "description": "Helios core — TypeScript/Bun port of Hazelcast distributed in-memory platform",
  "private": false,
  "workspaces": [
    "packages/nestjs",
    "packages/blitz",
    "packages/s3",
    "packages/mongodb",
    "packages/turso"
  ],
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    },
    "./server": {
      "import": "./dist/src/server/HeliosServer.js",
      "types": "./dist/src/server/HeliosServer.d.ts"
    },
    "./client": {
      "import": "./dist/src/client/HeliosClient.js",
      "types": "./dist/src/client/HeliosClient.d.ts"
    },
    "./client/config": {
      "import": "./dist/src/client/config/ClientConfig.js",
      "types": "./dist/src/client/config/ClientConfig.d.ts"
    }
  },
  "files": [
    "dist/src",
    "README.md"
  ],
  "scripts": {
    "build": "bun run tsc --project tsconfig.build.json",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:one": "bun test --test-name-pattern",
    "typecheck": "bun run tsc --noEmit",
    "test:mapstore:mongodb:unit": "bun test packages/mongodb/test/",
    "test:mapstore:mongodb:core": "bun test test/map/mapstore/Block19_3_BulkIO_Integration.test.ts test/map/mapstore/MapStoreIntegration.test.ts test/map/mapstore/Block19_1_CoreRuntime.test.ts",
    "test:mapstore:mongodb:offload": "bun test test/map/mapstore/Block19_3_BulkIO_Integration.test.ts --test-name-pattern 'Offload'",
    "test:mapstore:mongodb:cluster": "bun test test/map/mapstore/Block19_3_BulkIO_Integration.test.ts --test-name-pattern 'restart|cluster'",
    "test:mapstore:mongodb:e2e": "bun test test/map/mapstore/Block19_3_BulkIO_Integration.test.ts --test-name-pattern 'vertical slice|loadAllKeys|harness'",
    "test:mapstore:mongodb:wiring:implementation": "bun test test/map/mapstore/wiring/WiringImplementation.test.ts",
    "test:mapstore:mongodb:wiring:factory-implementation": "bun test test/map/mapstore/wiring/WiringFactoryImplementation.test.ts",
    "test:mapstore:mongodb:wiring:registry": "bun test test/map/mapstore/wiring/WiringRegistry.test.ts",
    "test:mapstore:mongodb:wiring:dynamic-programmatic": "bun test test/map/mapstore/wiring/WiringDynamicProgrammatic.test.ts",
    "test:mapstore:mongodb:wiring:dynamic-json": "bun test test/map/mapstore/wiring/WiringDynamicJson.test.ts",
    "test:mapstore:mongodb:wiring:dynamic-yaml": "bun test test/map/mapstore/wiring/WiringDynamicYaml.test.ts",
    "test:mapstore:mongodb:wiring:config-origin-relative": "bun test test/map/mapstore/wiring/WiringConfigOriginRelative.test.ts",
    "test:mapstore:mongodb:wiring:dynamic-package": "bun test test/map/mapstore/wiring/WiringDynamicPackage.test.ts",
    "test:mapstore:clustered:proof": "bun test test/cluster/tcp/ClusteredMapStoreProofTest.test.ts --timeout 30000",
    "test:mapstore:clustered:multiprocess": "bun test test/cluster/tcp/Block21_4_MultiProcessMapStoreProof.test.ts --timeout 60000",
    "test:mapstore:clustered:mongodb": "bun test packages/mongodb/test/MongoClusteredMapStore.test.ts --timeout 30000",
    "convert": "bun run scripts/convert-java-tests.ts",
    "prepack": "bun run build",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "hazelcast",
    "distributed",
    "in-memory",
    "cache",
    "map",
    "grid",
    "bun",
    "nestjs",
    "typescript"
  ],
  "author": "Helios Contributors",
  "license": "Apache-2.0",
  "dependencies": {
    "@zenystx/scatterjs": "0.1.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.3.3",
    "typescript": "beta"
  }
}
